// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Raffle {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String   @db.Text
  prizeImage    String
  galleryImages String[] @default([])
  videoUrl      String?
  features      Json     @default("[]")
  ticketPrice   Float
  totalTickets  Int
  drawDate      DateTime
  status        RaffleStatus @default(active)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tickets   Ticket[]
  purchases Purchase[]

  @@index([status])
  @@index([drawDate])
}

model Ticket {
  id         String      @id @default(cuid())
  raffleId   String
  number     Int
  status     TicketStatus @default(available)
  purchaseId String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  raffle   Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([raffleId, number])
  @@index([raffleId, status])
  @@index([purchaseId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@unique([phone])
  @@unique([email])
  @@index([phone])
}

model Purchase {
  id               String          @id @default(cuid())
  userId           String
  raffleId         String
  totalAmount      Float
  status           PurchaseStatus  @default(pending)
  paymentMethod    String?
  paymentReference String?
  paymentProofUrl  String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  raffle  Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([userId])
  @@index([raffleId])
  @@index([status])
  @@index([createdAt])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

enum RaffleStatus {
  active
  completed
}

enum TicketStatus {
  available
  reserved
  sold
}

enum PurchaseStatus {
  pending
  paid
  cancelled
}






