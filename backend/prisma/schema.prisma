// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Raffle {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String   @db.Text
  prizeImage    String
  galleryImages String[] @default([])
  videoUrl      String?
  features      Json     @default("[]")
  ticketPrice   Float
  totalTickets  Int
  drawDate      DateTime
  status        RaffleStatus @default(active)
  isVirtual     Boolean      @default(false)
  opportunities Int          @default(1)
  autoReleaseHours Int       @default(0)
  luckyMachineNumbers Int[]   @default([5, 10, 20, 50])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tickets   Ticket[]
  purchases Purchase[]

  @@index([status])
  @@index([drawDate])
}

model Ticket {
  id         String      @id @default(cuid())
  raffleId   String
  number     Int
  status     TicketStatus @default(available)
  isGift     Boolean      @default(false)
  purchaseId String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  raffle   Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([raffleId, number])
  @@index([raffleId, status])
  @@index([purchaseId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@unique([phone])
  @@index([phone])
}

model Purchase {
  id               String          @id @default(cuid())
  userId           String
  raffleId         String
  paymentMethodId  String?         // ID del método de pago seleccionado
  totalAmount      Float
  status           PurchaseStatus  @default(pending)
  paymentMethod    String?         // Nombre del banco (para compatibilidad)
  paymentReference String?
  paymentProofUrl  String?         @db.Text
  verificationStatus String?       // 'auto_verified' | 'pending_manual' | 'rejected'
  verificationNote String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  raffle         Raffle         @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  selectedMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  tickets        Ticket[]

  @@index([userId])
  @@index([raffleId])
  @@index([paymentMethodId])
  @@index([status])
  @@index([createdAt])
}


model Admin {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           String    @default("admin")
  planType       String?   // 'mensual' | 'por_rifa' | null
  planStartDate  DateTime?
  planExpiryDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model StoredImage {
  id        String   @id @default(cuid())
  data      Bytes    @db.ByteA
  mimeType  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model SystemSettings {
  id                       String   @id @default("default")
  bankName                 String   @default("BBVA México")
  clabe                   String   @default("012 180 0152 4895 2410")
  beneficiary              String   @default("Bismark México S.A.")
  accountNumber            String?
  paymentInstructions      String?  @db.Text
  whatsapp                 String   @default("+521234567890")
  contactEmail             String   @default("contacto@bismark.com")
  instagram                String   @default("@bismark_oficial")
  facebookUrl              String?
  autoVerificationEnabled  Boolean  @default(true)
  siteName                 String   @default("Bismark")
  logoUrl                  String?  @db.Text
  logoSize                 Int      @default(44)
  primaryColor             String   @default("#3b82f6")
  secondaryColor           String   @default("#6366f1")
  facebookPixelId          String?
  updatedAt                DateTime @updatedAt
}

model PaymentMethod {
  id            String   @id @default(cuid())
  bankName      String
  clabe         String
  beneficiary   String
  accountNumber String?
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases Purchase[]     // Compras que usaron este método
}


enum RaffleStatus {
  active
  completed
  draft
}

enum TicketStatus {
  available
  reserved
  sold
}

enum PurchaseStatus {
  pending
  paid
  cancelled
}






